parameters:
  level: 5
  paths:
    - lib
  checkMissingIterableValueType: false
  inferPrivatePropertyTypeFromConstructor: true
  checkGenericClassInNonGenericObjectType: false
  ignoreErrors:
    - '#Call to static method .* on an unknown class OC_.*#'
    - '#Class OC_.* not found#'
  bootstrapFiles:
    - tests/bootstrap.php
