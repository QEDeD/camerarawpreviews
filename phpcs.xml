<?xml version="1.0"?>
<ruleset name="CameraRawPreviews">
  <description>Minimal coding standard for CameraRawPreviews</description>
  <file>lib</file>
  <file>tests</file>
  <file>scripts</file>
  <exclude-pattern>vendor/*</exclude-pattern>
  <exclude-pattern>build/*</exclude-pattern>
  <exclude-pattern>nextcloud/*</exclude-pattern>

  <rule ref="PSR12">
    <exclude name="PSR1.Methods.CamelCapsMethodName.NotCamelCaps"/>
  </rule>

  <config name="ignore_warnings_on_exit" value="1"/>
</ruleset>
