{
	"name": "camerarawpreviews-dev",
	"build": {
		"dockerfile": "Dockerfile",
		"context": "..",
		"args": {
			"BASE_IMAGE": "mcr.microsoft.com/devcontainers/php:1-8.2-bookworm",
			"INSTALL_NODE": "no"
		}
	},
	// Use a Docker-managed volume for fast I/O on Windows/macOS
	"workspaceMount": "source=camerarawpreviews-workspace,target=/workspace,type=volume",
	"workspaceFolder": "/workspace",
	"remoteUser": "vscode",
	"customizations": {
		"vscode": {
			"settings": {
				"php.validate.executablePath": "/usr/local/bin/php",
				"editor.formatOnSave": false,
				"files.watcherExclude": {
					"**/vendor/**": true,
					"**/node_modules/**": true,
					"**/build/**": true,
					"**/tests/assets/cache/**": true,
					"**/.git/**": true
				},
				"search.exclude": {
					"**/vendor/**": true,
					"**/node_modules/**": true,
					"**/build/**": true,
					"**/tests/assets/cache/**": true
				}
			},
			"extensions": [
				"bmewburn.vscode-intelephense-client",
				"xdebug.php-debug"
			]
		}
	},
	"containerEnv": {
		// Set your repo URL and branch so the container can self-bootstrap an empty volume
		"GIT_REMOTE_URL": "https://github.com/QEDeD/camerarawpreviews.git",
		"CLONE_BRANCH": "master",
		"TZ": "${localEnv:TZ}"
	},
	"remoteEnv": {
		"COMPOSER_ALLOW_SUPERUSER": "1",
		"COMPOSER_CACHE_DIR": "/tmp/composer-cache"
	},
	"mounts": [
		"source=camerarawpreviews-composer-cache,target=/tmp/composer-cache,type=volume"
	],
	// Bootstrap the workspace inside the container volume, then verify env and install deps
	"postCreateCommand": "sudo /usr/local/bin/bootstrap-workspace",
	"forwardPorts": [8080],
	"runArgs": ["--init"],
	"hostRequirements": {
		"cpus": 2,
		"memory": "4gb"
	}
}
