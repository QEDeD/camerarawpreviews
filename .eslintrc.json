{
  "root": true,
  "extends": ["@nextcloud/eslint-config"],
  "env": {
    "browser": true,
    "es2021": true
  },
  "overrides": [
    {
      "files": ["js/**/*.js"],
      "parserOptions": {
        "ecmaVersion": 2021,
        "sourceType": "module"
      },
      "rules": {
        "no-console": ["error", {"allow": ["error", "warn"]}]
      }
    }
  ]
}
